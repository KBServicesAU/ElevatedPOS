{
  "name": "elevatedpos",
  "version": "1.6.0",
  "private": true,
  "description": "ElevatedPOS — Unified Commerce & Operations Platform",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "test": "turbo test",
    "test:integration": "turbo test:integration",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\" --ignore-path .gitignore",
    "db:generate": "turbo db:generate",
    "db:push": "turbo db:push",
    "db:migrate": "turbo db:migrate",
    "db:seed": "turbo db:seed",
    "docker:dev": "docker compose -f infrastructure/docker/docker-compose.dev.yml up -d",
    "docker:down": "docker compose -f infrastructure/docker/docker-compose.dev.yml down"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "prettier": "^3.3.2",
    "turbo": "^2.0.6",
    "typescript": "^5.5.2"
  },
  "packageManager": "pnpm@9.4.0",
  "pnpm": {
    "overrides": {
      "@react-native/gradle-plugin": "0.74.84",
      "expo-constants": "~16.0.2",
      "expo-linking": "~6.3.1",
      "react": "18.2.0",
      "react-native": "0.74.2",
      "react-native-safe-area-context": "4.10.1",
      "react-native-screens": "3.31.1"
    }
  }
}
