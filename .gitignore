# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
build/
.next/
.expo/
out/

# Environment — never commit real secrets
.env
.env.local
.env.*.local
# Environment-specific files that might contain real secrets
.env.production
.env.staging
.env.prod
# Allow .env.example and .env.test (checked-in defaults only, no real secrets)
!.env.example
!.env.test

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Editor
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# TypeScript
*.tsbuildinfo

# Test coverage
coverage/

# Turbo
.turbo/

# Playwright E2E
e2e/playwright-report/
e2e/test-results/
e2e/.playwright/

# Secrets and certificates — should never be committed
*.pem
*.key
*.p12
*.pfx
infrastructure/k8s/secrets.yaml
# (the .template variant IS committed — it has no real values)

# Terraform state — contains sensitive outputs
**/.terraform/
*.tfstate
*.tfstate.backup
*.tfvars
# Allow the example vars file
!*.tfvars.example

# Expo / React Native
.expo/
apps/mobile/android/
apps/mobile/ios/
apps/kiosk/android/
apps/kiosk/ios/
*.ipa
*.apk
credentials/

# Temp tool-result files
tool-results/
*.tool-results/

# Local secrets file — never commit
.secrets.production
.secrets.*
.claude/settings.local.json

# Claude Code local scratch — logs, screenshots, runtime locks, agent worktrees.
# The tracked .claude/ entries (launch.json, plans/, commands/, skills/) stay
# tracked because they're shared team config. Everything below is local-only.
.claude/apk-test/
.claude/worktrees/
.claude/scheduled_tasks.lock
.claude/tool-results/
.claude/*.log
.claude/*.tmp

# ANZ TIM API scratch — large SDK dumps + PDF transcriptions we keep locally
# for reference while working on the terminal integration. The REAL SDK files
# live under apps/mobile/assets/timapi/ and services/hardware-bridge/browser-test/
# — those ARE committed.
.anz-pdf-dump.txt
.anz-sdk-new/
.anz-sdk-old/

# Root-level temp/tool files
/*.json
/*.crt
/*.exe
/*.zip
/*.py
competitor-analysis.xlsx
