# KDS Display — environment variables
# Copy to .env.local for local development

# ── Server-side (used by Next.js API routes / server components) ──────────────

# Internal URL of the orders microservice.
# In docker-compose / k8s: http://orders:4004
# In local dev (outside docker): http://localhost:4004
ORDERS_SERVICE_URL=http://localhost:4004

# Shared secret for service-to-service calls (must match orders service).
INTERNAL_SECRET=elevatedpos_dev_internal_secret

# ── Client-side (exposed to the browser, must be prefixed NEXT_PUBLIC_) ───────

# Base URL of the orders service as seen from the browser.
# Used to build the WebSocket URL for the KDS stream.
# In production this is the public hostname proxied through nginx.
NEXT_PUBLIC_ORDERS_API_URL=http://localhost:4004

# Optional: pre-configure the location UUID so the connect screen is skipped.
# NEXT_PUBLIC_LOCATION_ID=00000000-0000-0000-0000-000000000001
