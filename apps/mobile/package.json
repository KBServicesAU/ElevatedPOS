{
  "name": "@nexus/mobile",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start --port 8083",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "build:apk": "eas build --profile preview --platform android",
    "build:ipa": "eas build --profile preview --platform ios",
    "build:prod-apk": "eas build --profile production --platform android",
    "build:prod-ipa": "eas build --profile production --platform ios",
    "submit:android": "eas submit --profile production --platform android",
    "submit:ios": "eas submit --profile production --platform ios",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/vector-icons": "^14.0.2",
    "@sentry/react-native": "~6.0.0",
    "@stripe/stripe-react-native": "0.38.0",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-native-community/netinfo": "^11.3.2",
    "expo": "~51.0.8",
    "expo-av": "~14.0.7",
    "expo-build-properties": "~0.12.5",
    "expo-constants": "~16.0.2",
    "expo-linking": "~6.3.1",
    "expo-modules-autolinking": "~1.11.1",
    "expo-modules-core": "~1.12.26",
    "expo-router": "~3.5.11",
    "expo-screen-orientation": "~7.0.5",
    "expo-secure-store": "~13.0.2",
    "expo-splash-screen": "~0.27.5",
    "expo-status-bar": "~1.12.1",
    "expo-updates": "^0.25.28",
    "react": "18.2.0",
    "react-native": "0.74.2",
    "react-native-safe-area-context": "4.10.1",
    "react-native-screens": "3.31.1",
    "react-native-thermal-receipt-printer": "1.2.0-rc.2",
    "react-native-webview": "13.8.6",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@types/react": "~18.2.79",
    "typescript": "^5.3.3"
  }
}
