# NEXUS Mobile — environment variables
# Copy to .env.local for local dev

# Base URL of the auth service (device pairing + device token auth)
EXPO_PUBLIC_API_URL=http://localhost:4001

# Orders service URL for KDS WebSocket
EXPO_PUBLIC_ORDERS_API_URL=http://localhost:4004

# Catalog service URL for POS/Kiosk product loading
EXPO_PUBLIC_CATALOG_API_URL=http://localhost:4002

# Optional: override the app name shown on screen
# EXPO_PUBLIC_APP_NAME=NEXUS

# EAS project ID (required for cloud builds)
# EAS_PROJECT_ID=your-eas-project-id

# iOS bundle ID override
# APP_BUNDLE_ID_IOS=com.yourcompany.nexus

# Android package override
# APP_PACKAGE_ANDROID=com.yourcompany.nexus
