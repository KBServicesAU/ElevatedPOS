{
  "cli": { "version": ">= 12.0.0", "appVersionSource": "local" },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": { "buildType": "apk" },
      "ios": { "simulator": false }
    },
    "preview": {
      "distribution": "internal",
      "android": { "buildType": "apk" },
      "ios": { "simulator": true }
    },
    "production": {
      "android": { "buildType": "apk" },
      "ios": {
        "credentialsSource": "remote",
        "enterpriseProvisioning": "adhoc"
      }
    },
    "production-pos": {
      "android": { "buildType": "apk", "env": { "EXPO_PUBLIC_ROLE_LOCK": "pos", "EXPO_PUBLIC_API_URL": "https://app.elevatedpos.com.au" } },
      "ios": { "credentialsSource": "remote", "enterpriseProvisioning": "adhoc", "env": { "EXPO_PUBLIC_ROLE_LOCK": "pos", "EXPO_PUBLIC_API_URL": "https://app.elevatedpos.com.au" } }
    },
    "production-kds": {
      "android": { "buildType": "apk", "env": { "EXPO_PUBLIC_ROLE_LOCK": "kds", "EXPO_PUBLIC_API_URL": "https://app.elevatedpos.com.au", "EXPO_PUBLIC_ORDERS_API_URL": "https://app.elevatedpos.com.au" } },
      "ios": { "credentialsSource": "remote", "enterpriseProvisioning": "adhoc", "env": { "EXPO_PUBLIC_ROLE_LOCK": "kds", "EXPO_PUBLIC_API_URL": "https://app.elevatedpos.com.au", "EXPO_PUBLIC_ORDERS_API_URL": "https://app.elevatedpos.com.au" } }
    },
    "production-kiosk": {
      "android": { "buildType": "apk", "env": { "EXPO_PUBLIC_ROLE_LOCK": "kiosk", "EXPO_PUBLIC_API_URL": "https://app.elevatedpos.com.au" } },
      "ios": { "credentialsSource": "remote", "enterpriseProvisioning": "adhoc", "env": { "EXPO_PUBLIC_ROLE_LOCK": "kiosk", "EXPO_PUBLIC_API_URL": "https://app.elevatedpos.com.au" } }
    }
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "../credentials/play-store-service-account.json",
        "track": "internal"
      }
    }
  }
}
