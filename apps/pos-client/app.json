{
  "expo": {
    "name": "ElevatedPOS",
    "slug": "elevatedpos-pos",
    "version": "1.0.0",
    "scheme": "elevatedpos",
    "platforms": ["ios", "android", "web"],
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/icon.png"
    },
    "icon": "./assets/icon.png",
    "splash": { "image": "./assets/splash.png", "backgroundColor": "#1e1e2e" },
    "ios": { "supportsTablet": true, "bundleIdentifier": "com.au.elevatedpos.client" },
    "android": { "adaptiveIcon": { "foregroundImage": "./assets/adaptive-icon.png", "backgroundColor": "#1e1e2e" }, "package": "com.au.elevatedpos.client" },
    "plugins": ["expo-router"]
  }
}
