# ElevatedPOS Web Backoffice — Environment Variables
# Copy this file to .env.local and fill in your values.
#
# DO NOT commit .env.local to version control.
# This file is safe to commit — it contains no secrets.

# ─── Microservice URLs ───────────────────────────────────────────────────────
# Base URLs for each internal microservice (no trailing slash).
# In production these should be internal service DNS names (e.g. http://auth-service:4001).

AUTH_API_URL=http://localhost:4001
CATALOG_API_URL=http://localhost:4002
INVENTORY_API_URL=http://localhost:4003
ORDERS_API_URL=http://localhost:4004
PAYMENTS_API_URL=http://localhost:4005
CUSTOMERS_API_URL=http://localhost:4006
LOYALTY_API_URL=http://localhost:4007
CAMPAIGNS_API_URL=http://localhost:4008
NOTIFICATIONS_API_URL=http://localhost:4009
INTEGRATIONS_API_URL=http://localhost:4010
AUTOMATIONS_API_URL=http://localhost:4011

# ─── Next.js / Auth ──────────────────────────────────────────────────────────
# NEXTAUTH_URL — the canonical URL of this Next.js app (used for OAuth callbacks).
NEXTAUTH_URL=http://localhost:3000

# NEXTAUTH_SECRET — random string used to sign session tokens.
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_32

# ─── Stripe Terminal ─────────────────────────────────────────────────────────
# Required to accept real card payments via Stripe Terminal.
# Leave blank to run POS in simulated mode (no real charges).
#
# Get keys at: https://dashboard.stripe.com/apikeys
# Use sk_test_... / pk_test_... for development.
# Use sk_live_... / pk_live_... for production.

STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ─── Public App URL ──────────────────────────────────────────────────────────
# The public-facing URL for this backoffice app (used in OAuth redirects and emails).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── POS Web App URL ─────────────────────────────────────────────────────────
# URL of the standalone POS web app (shown on the POS launch page).
NEXT_PUBLIC_POS_WEB_URL=http://localhost:8081
