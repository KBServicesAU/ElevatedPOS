{
  "name": "@nexus/catalog",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch --env-file .env src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "db:migrate": "drizzle-kit migrate",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/sensible": "^5.5.0",
    "@nexus/config": "workspace:*",
    "@nexus/fastify-audit": "workspace:*",
    "drizzle-orm": "^0.31.2",
    "fastify": "^4.28.1",
    "graphql": "^16.8.0",
    "ioredis": "^5.4.1",
    "mercurius": "^14.0.0",
    "pg": "^8.12.0",
    "typesense": "^1.8.2",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.6",
    "@types/uuid": "^10.0.0",
    "drizzle-kit": "^0.22.7",
    "tsx": "^4.15.7",
    "typescript": "^5.5.2",
    "vitest": "^1.6.0"
  }
}
