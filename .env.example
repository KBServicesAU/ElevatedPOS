# =============================================================
# NEXUS — Environment Configuration
# Copy to .env and fill in values
# =============================================================

# App
NODE_ENV=development
APP_NAME=NEXUS
APP_URL=http://localhost:3000

# Database (PostgreSQL)
DATABASE_URL=postgresql://nexus:nexus_dev@localhost:5432/nexus_dev
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# Redis
REDIS_URL=redis://localhost:6379

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=nexus-dev
KAFKA_GROUP_ID=nexus-dev-group

# Auth Service
AUTH_SERVICE_URL=http://localhost:4001
JWT_SECRET=change-me-in-production-use-256-bit-random-string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# Encryption
ENCRYPTION_KEY=change-me-32-char-hex-string-here

# Payments
TYRO_API_KEY=
TYRO_MERCHANT_ID=
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Email
POSTMARK_API_KEY=
EMAIL_FROM=noreply@nexus.app
EMAIL_FROM_NAME=NEXUS

# SMS
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Storage
AWS_REGION=ap-southeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=nexus-dev-assets
S3_CDN_URL=

# Search (Typesense)
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108
TYPESENSE_PROTOCOL=http
TYPESENSE_API_KEY=nexus-typesense-dev-key

# ClickHouse (analytics / reporting)
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_DB=nexus
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# AI
ANTHROPIC_API_KEY=

# Feature Flags
LAUNCHDARKLY_SDK_KEY=

# Observability
SENTRY_DSN=
DATADOG_API_KEY=

# Web Back Office
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_WS_URL=ws://localhost:4000

# Ports (services)
PORT_API_GATEWAY=4000
PORT_AUTH=4001
PORT_CATALOG=4002
PORT_INVENTORY=4003
PORT_ORDERS=4004
PORT_PAYMENTS=4005
PORT_CUSTOMERS=4006
PORT_LOYALTY=4007
PORT_CAMPAIGNS=4008
PORT_NOTIFICATIONS=4009
PORT_INTEGRATIONS=4010
PORT_AUTOMATIONS=4011
PORT_AI=4012
PORT_HARDWARE_BRIDGE=9999
PORT_FRANCHISE=4013
PORT_REPORTING=4014
PORT_WEBHOOKS=4015

# Hardware Bridge
HARDWARE_BRIDGE_URL=http://localhost:9999

# New services
FRANCHISE_API_URL=http://localhost:4013
REPORTING_API_URL=http://localhost:4014
WEBHOOKS_API_URL=http://localhost:4015

# Allowed CORS Origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# Temporal
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default

# Payments — Afterpay
AFTERPAY_MERCHANT_ID=
AFTERPAY_SECRET_KEY=
AFTERPAY_ENV=sandbox

# Payments — Zip (BNPL)
ZIP_MERCHANT_ID=
ZIP_API_KEY=

# Payments — Alipay / WeChat Pay
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
WECHAT_APP_ID=
WECHAT_MCH_ID=
WECHAT_API_KEY=

# Push Notifications (Firebase Cloud Messaging)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Webhook Signing
WEBHOOK_SIGNING_SECRET=change-me-in-production

# Logging
LOG_LEVEL=info

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# Bcrypt
BCRYPT_ROUNDS=12

# Internal service-to-service auth
INTERNAL_SECRET=change-me-in-production
