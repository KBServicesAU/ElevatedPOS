# ═══════════════════════════════════════════════════════════════════════════════
# elevatedpos-secrets — Kubernetes Secret template
# ═══════════════════════════════════════════════════════════════════════════════
#
# Copy to `secrets.yaml` (gitignored) and fill in real values, then:
#
#   kubectl apply -f infrastructure/k8s/secrets.yaml
#   kubectl rollout restart -n elevatedpos deploy/auth deploy/notifications \
#     deploy/integrations deploy/orders deploy/payments deploy/customers \
#     deploy/catalog deploy/inventory deploy/loyalty deploy/campaigns \
#     deploy/franchise deploy/automations deploy/ai deploy/reporting \
#     deploy/web-backoffice
#
# Verify the gitignore is wired so a real `secrets.yaml` never gets committed:
#   git check-ignore -v infrastructure/k8s/secrets.yaml
#
# ─── ⚠️  PROD vs DEV — READ THIS BEFORE EDITING ────────────────────────────────
#
# `DATABASE_URL` and `REDIS_URL` below ship with **dev/local** defaults
# (`postgres:5432`, `redis:6379`). Those values are correct for a developer
# running `docker compose up`, where Postgres + Redis are sidecar services
# inside the cluster network. They are **catastrophically wrong for prod**:
# a v2.7.55 prod rollout caused a partial outage when this template was
# applied as-is and every service tried to resolve `postgres` (an in-cluster
# DNS name that doesn't exist in prod) instead of the RDS endpoint.
#
# Before applying to a prod cluster you MUST replace:
#
#   1. `DATABASE_URL` host  → the RDS writer endpoint, e.g.
#      `elevatedpos-prod.<id>.ap-southeast-2.rds.amazonaws.com`.
#      Run `terraform output -raw rds_endpoint` to grab the current one.
#      Append `?sslmode=no-verify` (current setup) or `?sslmode=verify-full`
#      with the RDS CA bundle baked into the image (preferred — TODO).
#      The username on the RDS instance is `postgres`, NOT `elevatedpos`.
#      The database name is `elevatedpos`, NOT `elevatedpos_prod`.
#
#   2. `REDIS_URL` host → the ElastiCache primary endpoint, e.g.
#      `master.elevatedpos-prod.<id>.apse2.cache.amazonaws.com`.
#      Run `terraform output -raw redis_primary_endpoint` to grab it.
#      In prod ElastiCache uses encryption-in-transit, so the scheme is
#      `rediss://` (note the double `s`), not `redis://`.
#
# All other values are environment-agnostic — the placeholder `CHANGE_ME`
# tokens just need real secrets pasted over them.
# ───────────────────────────────────────────────────────────────────────────────

apiVersion: v1
kind: Secret
metadata:
  # Must match the `name:` referenced by every deployment's secretRef
  # (see infrastructure/k8s/services/*.yaml — all use `elevatedpos-secrets`).
  name: elevatedpos-secrets
  # Must match `infrastructure/k8s/namespace.yaml` (creates `elevatedpos`).
  namespace: elevatedpos
type: Opaque
stringData:
  # ── Datastores ───────────────────────────────────────────────────────────────
  # Dev default. PROD: replace `postgres:5432` with the RDS endpoint, swap
  # the username to `postgres`, the dbname to `elevatedpos`, and append
  # `?sslmode=no-verify`. See the warning at the top of this file.
  DATABASE_URL: "postgresql://elevatedpos:CHANGE_ME@postgres:5432/elevatedpos_prod"
  # Dev default. PROD: replace with `rediss://<elasticache-endpoint>:6379`.
  REDIS_URL: "redis://redis:6379"

  # ── Auth + crypto ────────────────────────────────────────────────────────────
  # Generate with: openssl rand -base64 32
  JWT_SECRET: "CHANGE_ME_min_32_chars"
  INTERNAL_SECRET: "CHANGE_ME_min_32_chars"
  NEXTAUTH_SECRET: "CHANGE_ME_min_32_chars"
  WEBHOOK_SIGNING_SECRET: "CHANGE_ME_min_32_chars"
  # Must be 32 bytes (64 hex chars) — generate with `openssl rand -hex 32`
  ENCRYPTION_KEY: "CHANGE_ME_64_hex_chars"

  # ── Stripe (live keys — rotate via Stripe dashboard if exposed) ──────────────
  STRIPE_SECRET_KEY: "sk_live_CHANGE_ME"
  STRIPE_WEBHOOK_SECRET: "whsec_CHANGE_ME"
  STRIPE_CONNECT_CLIENT_ID: "ca_CHANGE_ME"

  # ── Resend (transactional email) ─────────────────────────────────────────────
  RESEND_API_KEY: "re_CHANGE_ME"

  # ── ANZ Worldline TIM API ────────────────────────────────────────────────────
  # Integrator ID — server-side only, never expose to browser.
  ANZ_INTEGRATOR_ID: "CHANGE_ME"

  # ── Optional integrations ────────────────────────────────────────────────────
  # Anthropic AI — used by services/ai (catalog descriptions, churn risk, etc.)
  ANTHROPIC_API_KEY: "sk-ant-CHANGE_ME"
  # Typesense — used by services/catalog for product full-text search.
  TYPESENSE_API_KEY: "CHANGE_ME"
  # Tyro EFTPOS — partner API key, only set when the merchant opts in.
  TYRO_API_KEY: "CHANGE_ME"
